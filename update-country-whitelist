#!/usr/bin/env python3
"""
Fetch IPv4/IPv6 CIDR whitelists for selected countries, collapse overlapping
subnets to optimize firewall memory/lookup performance, and load them safely
into nftables using an A/B (Blue-Green) swap pattern to ensure zero network
downtime.

This script uses a high-priority pre-filter chain (priority -10) to drop
unwanted traffic BEFORE it hits the main input chain (priority 0).
"""

import os
import sys
import logging
import requests
import tempfile
import subprocess
import ipaddress
from pathlib import Path
from textwrap import indent
from typing import List, Tuple, Set

# ----------------------------------------------------------------------
# Configuration
# ----------------------------------------------------------------------

COUNTRIES: List[str] = ["DE"]

BASE_URL: str = (
    "https://raw.githubusercontent.com/ebrasha/cidr-ip-ranges-by-country/refs/heads/master/CIDR"
)

DEST: Path = Path("/etc/nftables.d/whitelist.nft")
FETCH_TIMEOUT: int = 20

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
)

# ----------------------------------------------------------------------
# Helper Functions
# ----------------------------------------------------------------------

def parse_cidr_lines(lines: List[str]) -> Tuple[Set[ipaddress.IPv4Network], Set[ipaddress.IPv6Network]]:
    """
    Parse text lines into validated IPv4 and IPv6 network objects.
    Any line that is not a valid network is ignored.
    """
    ipv4 = set()
    ipv6 = set()
    for lineno, line in enumerate(lines, 1):
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        try:
            # strict=False automatically masks the host bits
            net = ipaddress.ip_network(line, strict=False)
        except ValueError:
            logging.warning("Skipping invalid CIDR line %d: %r", lineno, line)
            continue
        if isinstance(net, ipaddress.IPv4Network):
            ipv4.add(net)
        else:
            ipv6.add(net)
    return ipv4, ipv6


def fetch_country_cidrs() -> Tuple[List[str], List[str]]:
    """Return optimized (ipv4, ipv6) string lists for configured countries."""
    all_ipv4: Set[ipaddress.IPv4Network] = set()
    all_ipv6: Set[ipaddress.IPv6Network] = set()
    session = requests.Session()

    for cc in COUNTRIES:
        cc = cc.strip().upper()
        if not cc:
            continue

        for family in ("ipv4", "ipv6"):
            url = f"{BASE_URL}/{cc}-{family}-Hackers.Zone.txt"
            logging.info("Fetching %s %s list...", cc, family)
            try:
                r = session.get(url, timeout=FETCH_TIMEOUT)
                r.raise_for_status()
            except requests.RequestException as e:
                logging.warning("Failed to fetch %s: %s", url, e)
                continue

            ipv4_set, ipv6_set = parse_cidr_lines(r.text.splitlines())
            all_ipv4 |= ipv4_set
            all_ipv6 |= ipv6_set

    total_raw = len(all_ipv4) + len(all_ipv6)
    logging.info("Fetched %d raw IPv4 and %d raw IPv6 CIDRs total.", len(all_ipv4), len(all_ipv6))

    # Collapse contiguous and overlapping subnet blocks to optimize set size
    collapsed_v4 = list(ipaddress.collapse_addresses(all_ipv4))
    collapsed_v6 = list(ipaddress.collapse_addresses(all_ipv6))
    total_collapsed = len(collapsed_v4) + len(collapsed_v6)

    logging.info(
        "Collapsed networks to %d IPv4 and %d IPv6 elements (reduced by %d entries).",
        len(collapsed_v4),
        len(collapsed_v6),
        total_raw - total_collapsed,
    )

    # Convert back to sorted string representations for rules
    return [str(net) for net in collapsed_v4], [str(net) for net in collapsed_v6]


# ----------------------------------------------------------------------
# Nftables File Formatting
# ----------------------------------------------------------------------

def format_elements_block(cidr_list: List[str], base_indent: int = 8) -> str:
    """Return a formatted 'elements = { ... }' string or empty string."""
    if not cidr_list:
        return ""
    cidr_indent = base_indent + 4
    inner = ",\n".join(cidr_list)
    return f"\n{indent('elements = {', ' ' * base_indent)}\n{indent(inner, ' ' * cidr_indent)}\n{indent('}', ' ' * base_indent)}"


def generate_whitelist_file(active: str, ipv4: List[str], ipv6: List[str]) -> str:
    """Generate the full content of the persistent whitelist file."""
    v4_a = ipv4 if active == "a" else []
    v4_b = ipv4 if active == "b" else []
    v6_a = ipv6 if active == "a" else []
    v6_b = ipv6 if active == "b" else []

    return f"""\
# This file is auto-generated by update-country-whitelist. Do not edit manually.
table inet filter {{
    set allowed_v4_a {{
        type ipv4_addr
        flags interval{format_elements_block(v4_a)}
    }}

    set allowed_v6_a {{
        type ipv6_addr
        flags interval{format_elements_block(v6_a)}
    }}

    set allowed_v4_b {{
        type ipv4_addr
        flags interval{format_elements_block(v4_b)}
    }}

    set allowed_v6_b {{
        type ipv6_addr
        flags interval{format_elements_block(v6_b)}
    }}

    chain whitelist_checker {{
        ip saddr @allowed_v4_{active} accept
        ip6 saddr @allowed_v6_{active} accept
    }}

    chain whitelist_prefilter {{
        type filter hook input priority -10;
        policy accept;

        # 1. Always allow loopback and established connections
        iifname "lo" accept
        ct state established,related accept

        # 2. Allow Tailscale interface globally
        iifname "tailscale0" accept

        # 3. Allow ICMP & IGMP to bypass geo-blocking
        meta l4proto {{ icmp, ipv6-icmp }} accept
        ip protocol igmp accept

        # 4. Allow inbound DHCPv6 replies
        ip6 nexthdr udp udp sport 547 udp dport 546 accept

        # 5. Check whitelist, if matched: pass to main chain (priority 0)
        jump whitelist_checker

        # 6. Drop everything else
        drop
    }}
}}
"""


# ----------------------------------------------------------------------
# Nftables Live Operations
# ----------------------------------------------------------------------

def get_active_suffix() -> str:
    """
    Determine which set suffix ('_a' or '_b') is currently active
    by inspecting the 'whitelist_checker' chain rules.
    """
    try:
        res = subprocess.run(
            ["nft", "list", "chain", "inet", "filter", "whitelist_checker"],
            capture_output=True,
            text=True,
            check=True
        )
        if "allowed_v4_b" in res.stdout:
            return "b"
    except subprocess.CalledProcessError:
        pass
    return "a"  # Default to 'a' if not found or if running for the first time


def load_set(set_name: str, elements: List[str]) -> None:
    """Populate an nftables set in a single, safe transaction."""
    # 1. Clear any old data in the target set first
    subprocess.run(["nft", "flush", "set", "inet", "filter", set_name], check=True)

    if not elements:
        return

    # 2. Add all elements in one command
    logging.info("Loading %s (%d elements)...", set_name, len(elements))
    elem_string = ", ".join(elements)
    
    # Inject elements through stdin directly to the nft executable
    cmd = f"add element inet filter {set_name} {{ {elem_string} }}"
    subprocess.run(["nft", "-f", "-"], input=cmd, text=True, check=True)


def write_atomic_file(content: str, directory: Path) -> Path:
    """Write content atomically to a file under directory and return its Path."""
    with tempfile.NamedTemporaryFile("w", dir=directory, suffix=".nft", delete=False) as tmp:
        tmp.write(content)
        tmp.flush()
        os.fsync(tmp.fileno())
        temp_path = Path(tmp.name)
    return temp_path


def bootstrap_if_needed() -> None:
    """Ensure the target directory and skeleton file exist, and load them into nftables."""
    if DEST.exists() and DEST.stat().st_size > 0:
        return

    logging.info("Dynamic whitelist file missing or empty. Bootstrapping configurations...")
    
    # 1. Create directory structures if missing
    DEST.parent.mkdir(parents=True, exist_ok=True)

    # 2. Write empty skeleton file (Set A active, but empty)
    skeleton = generate_whitelist_file("a", [], [])
    tmp_path = write_atomic_file(skeleton, DEST.parent)
    tmp_path.replace(DEST)

    # 3. Reload main nftables ruleset to apply structures to kernel
    logging.info("Applying base system nftables ruleset to register dynamic chains...")
    try:
        subprocess.run(
            ["nft", "-f", "/etc/nftables.conf"], 
            check=True, 
            capture_output=True, 
            text=True
        )
    except subprocess.CalledProcessError as e:
        logging.error("Failed to load /etc/nftables.conf: %s", e.stderr)
        raise RuntimeError("Base nftables initialization failed during bootstrap") from e


# ----------------------------------------------------------------------
# Main entry point
# ----------------------------------------------------------------------

def main() -> int:
    try:
        # 1. Check and bootstrap directories, skeleton files, and firewall chains
        bootstrap_if_needed()

        # 2. Fetch, parse and optimize CIDRs
        ipv4, ipv6 = fetch_country_cidrs()
        if not ipv4 and not ipv6:
            logging.warning("No CIDRs fetched, aborting update.")
            return 1

        # 3. Detect running environment ('a' or 'b')
        active = get_active_suffix()
        target = "b" if active == "a" else "a"
        logging.info("Active set: _%s. Targeting inactive set: _%s for loading.", active, target)

        # 4. Load elements into inactive set
        load_set(f"allowed_v4_{target}", ipv4)
        load_set(f"allowed_v6_{target}", ipv6)

        # 5. Atomically swap traffic to use the newly populated set
        logging.info("Performing atomic swap to set _%s...", target)
        swap_instructions = f"""
        flush chain inet filter whitelist_checker
        add rule inet filter whitelist_checker ip saddr @allowed_v4_{target} accept
        add rule inet filter whitelist_checker ip6 saddr @allowed_v6_{target} accept
        """
        subprocess.run(["nft", "-f", "-"], input=swap_instructions, text=True, check=True)

        # 6. Flush the now-inactive set to release system memory
        logging.info("Cleaning up old active set _%s...", active)
        cleanup_instructions = f"""
        flush set inet filter allowed_v4_{active}
        flush set inet filter allowed_v6_{active}
        """
        subprocess.run(["nft", "-f", "-"], input=cleanup_instructions, text=True, check=True)

        # 7. Generate and save the configuration file for persistence on reboots
        logging.info("Saving active state to %s...", DEST)
        file_content = generate_whitelist_file(target, ipv4, ipv6)
        tmp_path = write_atomic_file(file_content, DEST.parent)
        tmp_path.replace(DEST)

        logging.info("✅ Whitelist updated successfully with zero downtime.")
        return 0

    except Exception as e:
        logging.exception("❌ Update failed: %s", e)
        return 1


if __name__ == "__main__":
    sys.exit(main())
